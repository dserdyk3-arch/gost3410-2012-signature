#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
ГОСТ Р 34.10-2012
Реализация электронной подписи (256 бит)
Параметры: id-tc26-gost-3410-12-256-paramSetA
"""

from gostcrypto import gosthash
import secrets
import os

# ============================================================
# ПАРАМЕТРЫ ГОСТ Р 34.10-2012 (TC26 paramSetA)
# ============================================================

curve_p = int("FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFD97", 16)
curve_a = int("FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFD94", 16)
curve_b = int("A6", 16)
curve_q = int("FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF6C611070995AD10045841B09B761B893", 16)

Px = int("1", 16)
Py = int("8D91E471E0989CDA27DF505A453F2B7635294F2B6E0F8E1C58E7B7E4E4D8E2F", 16)

BASE_POINT = (Px, Py)

# ============================================================
# ХЭШ (ГОСТ 34.11-2012)
# ============================================================

def hash_message(message: bytes) -> int:
    h = gosthash.new("streebog256", data=message).digest()
    return int.from_bytes(h, byteorder="big")

# ============================================================
# РАСШИРЕННЫЙ АЛГОРИТМ ЕВКЛИДА
# ============================================================

def gcd_extended(a, b):
    if a == 0:
        return b, 0, 1
    gcd, x1, y1 = gcd_extended(b % a, a)
    x = y1 - (b // a) * x1
    y = x1
    return gcd, x, y

def mod_inv(x, m):
    gcd, inv, _ = gcd_extended(x % m, m)
    if gcd != 1:
        raise ValueError("Обратный элемент не существует")
    return inv % m

# ============================================================
# ОПЕРАЦИИ С ТОЧКАМИ
# ============================================================

def point_double(P):
    if P is None:
        return None

    x1, y1 = P

    if y1 % curve_p == 0:
        return None

    lam = (3 * x1 * x1 + curve_a) * mod_inv((2 * y1) % curve_p, curve_p) % curve_p
    x3 = (lam * lam - 2 * x1) % curve_p
    y3 = (lam * (x1 - x3) - y1) % curve_p

    return (x3, y3)

def point_add(P1, P2):
    if P1 is None:
        return P2
    if P2 is None:
        return P1

    x1, y1 = P1
    x2, y2 = P2

    if x1 == x2:
        if (y1 + y2) % curve_p == 0:
            return None
        return point_double(P1)

    lam = (y2 - y1) * mod_inv((x2 - x1) % curve_p, curve_p) % curve_p
    x3 = (lam * lam - x1 - x2) % curve_p
    y3 = (lam * (x1 - x3) - y1) % curve_p

    return (x3, y3)

def point_mul(k, P):
    result = None
    addend = P

    while k > 0:
        if k & 1:
            result = point_add(result, addend)
        addend = point_double(addend)
        k >>= 1

    return result

# ============================================================
# ГЕНЕРАЦИЯ КЛЮЧЕЙ
# ============================================================

def generate_keys():
    d = secrets.randbelow(curve_q - 1) + 1
    Q = point_mul(d, BASE_POINT)
    return d, Q

# ============================================================
# ПОДПИСЬ
# ============================================================

def sign(message: bytes, d: int):
    h = hash_message(message)
    e = h % curve_q
    if e == 0:
        e = 1

    while True:
        k = secrets.randbelow(curve_q - 1) + 1
        C = point_mul(k, BASE_POINT)
        if C is None:
            continue

        r = C[0] % curve_q
        if r == 0:
            continue

        s = (r * d + k * e) % curve_q
        if s == 0:
            continue

        return (r, s)

# ============================================================
# ПРОВЕРКА
# ============================================================

def verify(message: bytes, signature, Q):
    r, s = signature

    if not (0 < r < curve_q and 0 < s < curve_q):
        return False

    h = hash_message(message)
    e = h % curve_q
    if e == 0:
        e = 1

    v = mod_inv(e, curve_q)
    z1 = (s * v) % curve_q
    z2 = (-r * v) % curve_q

    C = point_add(
        point_mul(z1, BASE_POINT),
        point_mul(z2, Q)
    )

    if C is None:
        return False

    R = C[0] % curve_q
    return R == r

# ============================================================
# МЕНЮ
# ============================================================

def main():
    private_key = None
    public_key = None

    while True:
        print("\n" + "=" * 50)
        print("ГОСТ Р 34.10-2012")
        print("=" * 50)
        print("1. Сгенерировать ключи")
        print("2. Подписать файл")
        print("3. Проверить подпись")
        print("0. Выход")
        print("-" * 50)

        choice = input("Выбор: ").strip()

        if choice == "1":
            private_key, public_key = generate_keys()

            with open("private_key.txt", "w") as f:
                f.write(str(private_key))

            with open("public_key.txt", "w") as f:
                f.write(f"{public_key[0]}\n{public_key[1]}")

            print("✅ Ключи сгенерированы.")

        elif choice == "2":
            if private_key is None:
                print("Сначала сгенерируйте ключи.")
                continue

            filename = input("Имя файла для подписи: ").strip()

            if not os.path.exists(filename):
                print("Файл не найден.")
                continue

            with open(filename, "rb") as f:
                data = f.read()

            signature = sign(data, private_key)

            with open("signature.sig", "w") as f:
                f.write(f"{signature[0]}\n{signature[1]}")

            print("✅ Подпись сформирована.")

        elif choice == "3":
            if public_key is None:
                print("Сначала сгенерируйте ключи.")
                continue

            filename = input("Имя файла для проверки: ").strip()

            if not os.path.exists(filename):
                print("Файл не найден.")
                continue

            with open(filename, "rb") as f:
                data = f.read()

            with open("signature.sig", "r") as f:
                r = int(f.readline().strip())
                s = int(f.readline().strip())

            if verify(data, (r, s), public_key):
                print("✅ ПОДПИСЬ ВЕРНА")
            else:
                print("❌ ПОДПИСЬ НЕВЕРНА")

        elif choice == "0":
            break

if __name__ == "__main__":
    main()

